<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вариант 3"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnAddFigure"
        android:layout_width="280dp"
        android:layout_height="70dp"
        android:text="Добавить фигуру (долгое нажатие)"
        android:layout_marginBottom="40dp" />

    <LinearLayout
        android:id="@+id/figuresContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Главное меню: три точки сверху\nКонтекстное меню: долгое нажатие на кнопку"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="40dp" />

</LinearLayout>